# ============================================================
# LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# ============================================================

# ─── Database ────────────────────────────────────────────────
# Option A: Use local PostgreSQL via docker-compose
DB_HOST=localhost
DB_PORT=5432
DB_NAME=automation_test
DB_USER=postgres
DB_PASSWORD=postgres

# Option B: Use Neon for local dev (uncomment and set DATABASE_URL)
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST.neon.tech/neondb?sslmode=require

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=dev_secret_key_replace_in_production
JWT_EXPIRES_IN=7d

# ─── LLM / AI — Test Generation (server-side) ────────────────
# Options: gemini | ollama | openai
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ─── LLM / AI — Agent Execution (agent-worker) ───────────────
EXECUTION_LLM_PROVIDER=gemini
EXECUTION_LLM_MODEL=gemini-2.5-flash
# --- OR use Ollama locally ---
# EXECUTION_LLM_PROVIDER=ollama
# EXECUTION_LLM_MODEL=gemma3:4b
# OLLAMA_BASE_URL=http://localhost:11434

EXECUTION_MAX_STEPS=20
EXECUTION_TIMEOUT_SECONDS=300
EXECUTION_USE_VISION=true
EXECUTION_HEADLESS=true
EXECUTION_BROWSER_TYPE=

# ─── Agent Worker ─────────────────────────────────────────────
AGENT_WORKER_BASE_URL=http://localhost:8001
AGENT_CALLBACK_SECRET=
NODE_CALLBACK_BASE_URL=http://localhost:5000/api
SCREENSHOTS_DIR=../server/screenshots
WORKER_MAX_CONCURRENCY=3

# ─── Client (Vite) ────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=AutomationTest
VITE_ENV=development
