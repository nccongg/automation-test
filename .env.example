# =============================
# DATABASE CONFIG
# =============================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Automation_testing_DB
DB_USER=postgres
DB_PASSWORD=123456

# =============================
# SERVER CONFIG
# =============================
PORT=5000
NODE_ENV=development
BODY_LIMIT=10mb

# =============================
# GENERATION LLM (for generating test cases)
# =============================
GENERATION_LLM_PROVIDER=ollama
GENERATION_LLM_MODEL=gemma3:4b

# =============================
# EXECUTION LLM (for running test cases in agent-worker)
# =============================
EXECUTION_LLM_PROVIDER=gemini
EXECUTION_LLM_MODEL=gemini-2.5-flash

# =============================
# GEMINI / GOOGLE
# =============================
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=key-here

# =============================
# AGENT WORKER
# =============================
AGENT_WORKER_BASE_URL=http://localhost:8001
AGENT_CALLBACK_SECRET=super-secret
NODE_CALLBACK_BASE_URL=http://localhost:5000/api

# =============================
# SELENIUM CONFIG
# =============================
SELENIUM_BROWSER=chrome
SELENIUM_HEADLESS=false
SCREENSHOTS_DIR=./screenshots