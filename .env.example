LLM_MODEL=gemma3:4b

GEMINI_API_KEY=AIzaSyC04o6H8h7eutWjJHYCkJ-I6paxNjbzzzU---------
# OPENAI_API_KEY=

# =============================
# LLM / AI — Agent Execution (browser-use, agent-worker)
# =============================
# Switch provider by uncommenting one block:

# --- Ollama (local, no API key needed) ---
EXECUTION_LLM_PROVIDER=ollama
EXECUTION_LLM_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434

# --- Gemini ---
# EXECUTION_LLM_PROVIDER=gemini
# EXECUTION_LLM_MODEL=gemini-2.5-flash

# --- OpenAI ---
# EXECUTION_LLM_PROVIDER=openai
# EXECUTION_LLM_MODEL=gpt-4o

# Agent execution settings
EXECUTION_MAX_STEPS=20
EXECUTION_TIMEOUT_SECONDS=300
EXECUTION_USE_VISION=true
EXECUTION_HEADLESS=true
EXECUTION_BROWSER_TYPE=



# =============================
# AGENT WORKER
# =============================
AGENT_WORKER_BASE_URL=http://localhost:8001
AGENT_CALLBACK_SECRET=
NODE_CALLBACK_BASE_URL=http://localhost:3001/api
