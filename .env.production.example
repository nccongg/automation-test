# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ─── Database ────────────────────────────────────────────────
# Use DATABASE_URL for cloud databases (Neon, Supabase, Railway).
# When DATABASE_URL is set, individual DB_* vars are ignored.
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST.neon.tech/neondb?sslmode=require

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# Public URL of the backend (used by agent-worker callbacks and crawl results).
# On Render: https://your-backend.onrender.com
# On Railway: https://your-backend.up.railway.app
SERVER_BASE_URL=https://your-backend.onrender.com

# ─── Auth ────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS
JWT_EXPIRES_IN=7d

# ─── LLM / AI — Test Generation (server-side) ────────────────
# Options: gemini | openai
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ─── LLM / AI — Agent Execution (agent-worker) ───────────────
EXECUTION_LLM_PROVIDER=gemini
EXECUTION_LLM_MODEL=gemini-2.5-flash
EXECUTION_MAX_STEPS=20
EXECUTION_TIMEOUT_SECONDS=300
EXECUTION_USE_VISION=true
EXECUTION_HEADLESS=true
EXECUTION_BROWSER_TYPE=

# ─── Agent Worker ─────────────────────────────────────────────
# URL of the deployed agent-worker service
AGENT_WORKER_BASE_URL=https://your-agent-worker.onrender.com

# Shared secret between server and agent-worker for callbacks
# Generate: openssl rand -hex 32
AGENT_CALLBACK_SECRET=REPLACE_WITH_RANDOM_SECRET

# URL the agent-worker POSTs results back to (your backend)
NODE_CALLBACK_BASE_URL=https://your-backend.onrender.com/api

# Path where screenshots are stored inside the container/server
SCREENSHOTS_DIR=/app/screenshots

# Maximum concurrent browser sessions in agent-worker
WORKER_MAX_CONCURRENCY=2

# ─── Client (Vite — build time only) ─────────────────────────
VITE_API_URL=https://your-backend.onrender.com/api
VITE_APP_NAME=AutomationTest
VITE_ENV=production
